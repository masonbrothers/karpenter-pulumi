{
  "name": "karpenter-pulumi",
  "version": "0.1.0",
  "description": "Pulumi TypeScript helpers for installing Karpenter on AWS EKS and declaring v1 NodePools.",
  "license": "MIT AND Apache-2.0",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/masonbrothers/karpenter-pulumi.git"
  },
  "bugs": {
    "url": "https://github.com/masonbrothers/karpenter-pulumi/issues"
  },
  "homepage": "https://github.com/masonbrothers/karpenter-pulumi#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.16.0"
  },
  "packageManager": "pnpm@10.7.1",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "crds",
    "crd2pulumi.config.mjs",
    "dist",
    "LICENSE.md",
    "README.md",
    "THIRD_PARTY_LICENSES",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { force: true, recursive: true })\"",
    "build": "pnpm clean && tsc -p tsconfig.json",
    "generate:crds": "generate-crd2pulumi-package",
    "test": "vitest run",
    "test:dist": "node test/dist-smoke.cjs",
    "test:kind": "smoke-crd2pulumi-kubernetes",
    "test:pack": "smoke-crd2pulumi-package",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./aws": {
      "types": "./dist/aws.d.ts",
      "require": "./dist/aws.js",
      "import": "./dist/aws.js"
    },
    "./resources": {
      "types": "./dist/resources.d.ts",
      "require": "./dist/resources.js",
      "import": "./dist/resources.js"
    },
    "./defaults": {
      "types": "./dist/defaults.d.ts",
      "require": "./dist/defaults.js",
      "import": "./dist/defaults.js"
    }
  },
  "peerDependencies": {
    "@pulumi/aws": ">=6.66.0 <8",
    "@pulumi/aws-native": ">=1.25.0 <3",
    "@pulumi/kubernetes": ">=4.18.0 <6",
    "@pulumi/pulumi": ">=3.144.0 <5"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "crd2pulumi-package-tools": "github:masonbrothers/crd2pulumi-package-tools#d82813ab4e8def5e1aa04085be7832f5bd628246",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
